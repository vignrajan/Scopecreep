# ─── Supabase ───────────────────────────────────────────────
# Project URL and anon key from Supabase dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Service role key — SERVER ONLY. Never expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─── Anthropic (Claude) ─────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-your-key

# ─── Lemon Squeezy ──────────────────────────────────────────
# API key: Settings → API. Store ID: Settings → Stores (numeric id).
LEMONSQUEEZY_API_KEY=your-ls-api-key
LEMONSQUEEZY_STORE_ID=12345
# Webhook signing secret you set when creating the webhook in LS.
LEMONSQUEEZY_WEBHOOK_SECRET=your-webhook-secret
# Variant IDs for each paid plan (Products → Variant → "..." → Copy ID).
LEMONSQUEEZY_PRO_VARIANT_ID=000001
LEMONSQUEEZY_AGENCY_VARIANT_ID=000002

# ─── Resend ─────────────────────────────────────────────────
RESEND_API_KEY=re_your-key
# Verified sender, e.g. "ScopeLock <noreply@yourdomain.com>"
EMAIL_FROM=ScopeLock <noreply@yourdomain.com>

# ─── App ────────────────────────────────────────────────────
# Public base URL used to build share links, sign links, and checkout redirects.
# Locally: http://localhost:3000 ; in prod: your deployed domain.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Secret used to authenticate the Vercel Cron weekly-summary endpoint.
CRON_SECRET=generate-a-long-random-string

# ─── Sentry (optional — error monitoring) ──────────────────
# Leave unset to disable Sentry entirely (the app runs fine without it).
NEXT_PUBLIC_SENTRY_DSN=
# Only needed to upload source maps during the build (CI/Vercel):
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=

# Vercel Analytics needs no keys — it activates automatically on Vercel.
